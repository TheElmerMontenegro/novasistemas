<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NovaSistemas — Novafiber</title>
  <meta name="description"
    content="Portal de sistemas internos de Novafiber. Accede a NovaActivos, NovaCronos, NovaTicket, NovaBackup y NovaImpresoras." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />

  <style>
    /* =============================================
       RESET & VARIABLES
    ============================================= */
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --nova-green: #6ea44e;
      --nova-green-dark: #527a3a;
      --nova-green-light: #8fc46e;
      --nova-accent: #6ea44e;
      --bg-dark: #222d35;
      --bg-card: #2a3640;
      --bg-card-hover: #313f4a;
      --border: rgba(255, 255, 255, 0.1);
      --text-primary: #ffffff;
      --text-secondary: #b0bec5;
      --error: #e57373;
      --success: #6ea44e;
      --radius: 16px;
      --radius-sm: 10px;
      --shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
      --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    html,
    body {
      height: 100%;
      font-family: 'Inter', sans-serif;
      background: var(--bg-dark);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    /* =============================================
       UTILITIES
    ============================================= */
    .hidden {
      display: none !important;
    }

    /* =============================================
       ═══════════  LOGIN PAGE  ═══════════
    ============================================= */
    #login-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    /* Animated gradient background */
    #login-page::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 40%, rgba(61, 155, 63, 0.18) 0%, transparent 60%),
        radial-gradient(ellipse 60% 80% at 80% 80%, rgba(0, 212, 170, 0.12) 0%, transparent 60%),
        linear-gradient(135deg, #0d1117 0%, #141b25 50%, #0d1117 100%);
      z-index: 0;
      animation: bgPulse 8s ease-in-out infinite alternate;
    }

    @keyframes bgPulse {
      from {
        filter: brightness(1);
      }

      to {
        filter: brightness(1.1);
      }
    }

    /* Floating particles */
    #login-page::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        radial-gradient(circle 2px at 15% 25%, rgba(61, 155, 63, 0.4) 0%, transparent 100%),
        radial-gradient(circle 1px at 70% 15%, rgba(0, 212, 170, 0.3) 0%, transparent 100%),
        radial-gradient(circle 2px at 85% 60%, rgba(61, 155, 63, 0.3) 0%, transparent 100%),
        radial-gradient(circle 1px at 30% 80%, rgba(0, 212, 170, 0.2) 0%, transparent 100%),
        radial-gradient(circle 3px at 55% 45%, rgba(61, 155, 63, 0.15) 0%, transparent 100%);
      z-index: 0;
      animation: float 15s ease-in-out infinite alternate;
    }

    @keyframes float {
      from {
        transform: translateY(0px) translateX(0px);
      }

      to {
        transform: translateY(-20px) translateX(10px);
      }
    }

    .login-container {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 440px;
      padding: 1rem;
    }

    .login-card {
      background: rgba(22, 27, 34, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 2.5rem 2.25rem;
      box-shadow: var(--shadow), 0 0 0 1px rgba(61, 155, 63, 0.1);
      animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(40px) scale(0.95);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .login-brand {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 2rem;
      gap: 0.75rem;
    }

    .login-brand .brand-icon {
      width: 64px;
      height: 64px;
      background: linear-gradient(135deg, var(--nova-green), var(--nova-accent));
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      box-shadow: 0 4px 24px rgba(61, 155, 63, 0.4);
      animation: iconGlow 2s ease-in-out infinite alternate;
    }

    @keyframes iconGlow {
      from {
        box-shadow: 0 4px 24px rgba(61, 155, 63, 0.4);
      }

      to {
        box-shadow: 0 4px 40px rgba(61, 155, 63, 0.7);
      }
    }

    .login-brand h1 {
      font-size: 1.6rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, var(--text-primary) 0%, var(--nova-green-light) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .login-brand p {
      font-size: 0.82rem;
      color: var(--text-secondary);
      letter-spacing: 0.5px;
    }

    .form-group {
      margin-bottom: 1.1rem;
    }

    .form-group label {
      display: block;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 0.45rem;
    }

    .input-wrap {
      position: relative;
    }

    .input-wrap .input-icon {
      position: absolute;
      left: 0.9rem;
      top: 50%;
      transform: translateY(-50%);
      font-size: 1rem;
      pointer-events: none;
      opacity: 0.5;
    }

    .form-group input {
      width: 100%;
      padding: 0.75rem 1rem 0.75rem 2.6rem;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      color: var(--text-primary);
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      outline: none;
      transition: border-color var(--transition), background var(--transition), box-shadow var(--transition);
    }

    .form-group input:focus {
      border-color: var(--nova-green);
      background: rgba(61, 155, 63, 0.07);
      box-shadow: 0 0 0 3px rgba(61, 155, 63, 0.15);
    }

    .form-group input::placeholder {
      color: rgba(139, 148, 158, 0.6);
    }

    #login-error {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(248, 81, 73, 0.12);
      border: 1px solid rgba(248, 81, 73, 0.3);
      border-radius: var(--radius-sm);
      padding: 0.65rem 0.9rem;
      color: var(--error);
      font-size: 0.85rem;
      font-weight: 500;
      margin-bottom: 1rem;
      animation: shake 0.3s ease;
    }

    @keyframes shake {

      0%,
      100% {
        transform: translateX(0);
      }

      25% {
        transform: translateX(-6px);
      }

      75% {
        transform: translateX(6px);
      }
    }

    .btn-login {
      width: 100%;
      padding: 0.85rem;
      background: linear-gradient(135deg, var(--nova-green), var(--nova-green-dark));
      border: none;
      border-radius: var(--radius-sm);
      color: #fff;
      font-family: 'Inter', sans-serif;
      font-size: 0.98rem;
      font-weight: 700;
      letter-spacing: 0.3px;
      cursor: pointer;
      transition: all var(--transition);
      position: relative;
      overflow: hidden;
      margin-top: 0.5rem;
    }

    .btn-login::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.15), transparent);
      opacity: 0;
      transition: opacity var(--transition);
    }

    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(61, 155, 63, 0.5);
    }

    .btn-login:hover::after {
      opacity: 1;
    }

    .btn-login:active {
      transform: translateY(0);
    }

    .login-footer {
      text-align: center;
      margin-top: 1.5rem;
      color: var(--text-secondary);
      font-size: 0.78rem;
      opacity: 0.7;
    }

    /* =============================================
       ═══════════  DASHBOARD  ═══════════
    ============================================= */
    #dashboard-page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      position: relative;
    }

    /* Hero background with tech overlay */
    #dashboard-page::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        linear-gradient(135deg, rgba(0, 0, 0, 0.85) 0%, rgba(13, 17, 23, 0.9) 100%),
        url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%233d9b3f' fill-opacity='0.06'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      z-index: 0;
      pointer-events: none;
    }

    /* ── Header ── */
    .header {
      position: relative;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      height: 70px;
      background: rgba(13, 17, 23, 0.9);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      box-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
    }

    .header-brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .header-logo {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, var(--nova-green), var(--nova-accent));
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }

    .header-titles h2 {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.2;
    }

    .header-titles span {
      font-size: 0.72rem;
      color: var(--nova-green-light);
      font-weight: 500;
      letter-spacing: 0.5px;
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .user-badge {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.35rem 0.75rem;
      background: rgba(61, 155, 63, 0.12);
      border: 1px solid rgba(61, 155, 63, 0.25);
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--nova-green-light);
    }

    .user-badge .user-dot {
      width: 7px;
      height: 7px;
      background: var(--nova-green-light);
      border-radius: 50%;
      animation: pulse 1.5s ease-in-out infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: 0.5;
        transform: scale(0.8);
      }
    }

    .btn-logout {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1rem;
      background: rgba(248, 81, 73, 0.12);
      border: 1px solid rgba(248, 81, 73, 0.25);
      border-radius: var(--radius-sm);
      color: var(--error);
      font-family: 'Inter', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      transition: all var(--transition);
    }

    .btn-logout:hover {
      background: rgba(248, 81, 73, 0.22);
      border-color: rgba(248, 81, 73, 0.5);
      transform: translateY(-1px);
    }

    /* ── Welcome Banner ── */
    .welcome-banner {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 2.5rem 1rem 1.5rem;
    }

    .welcome-banner h3 {
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 800;
      background: linear-gradient(135deg, var(--text-primary) 0%, var(--nova-green-light) 60%, var(--nova-accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.5rem;
    }

    .welcome-banner p {
      color: var(--text-secondary);
      font-size: 0.9rem;
    }

    /* ── Cards Grid ── */
    .cards-section {
      position: relative;
      z-index: 1;
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 2rem 3rem;
    }

    .cards-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      justify-content: center;
      max-width: 960px;
      width: 100%;
    }

    /* ── Individual Card ── */
    .sys-card {
      position: relative;
      width: 200px;
      background: rgba(22, 27, 34, 0.8);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 1.75rem 1.25rem 1.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.85rem;
      cursor: pointer;
      text-decoration: none;
      color: var(--text-primary);
      transition: all var(--transition);
      overflow: visible;
      animation: cardIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    .sys-card:nth-child(1) {
      animation-delay: 0.05s;
    }

    .sys-card:nth-child(2) {
      animation-delay: 0.10s;
    }

    .sys-card:nth-child(3) {
      animation-delay: 0.15s;
    }

    .sys-card:nth-child(4) {
      animation-delay: 0.20s;
    }

    .sys-card:nth-child(5) {
      animation-delay: 0.25s;
    }

    @keyframes cardIn {
      from {
        opacity: 0;
        transform: translateY(30px) scale(0.9);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .sys-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 20px;
      background: linear-gradient(135deg, var(--nova-green), var(--nova-accent));
      opacity: 0;
      transition: opacity var(--transition);
      z-index: 0;
    }

    .sys-card:hover {
      transform: translateY(-8px) scale(1.04);
      border-color: rgba(61, 155, 63, 0.5);
      box-shadow: 0 20px 48px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(61, 155, 63, 0.2), 0 0 30px rgba(61, 155, 63, 0.15);
    }

    .sys-card:hover::before {
      opacity: 0.06;
    }

    .card-icon-wrap {
      position: relative;
      z-index: 1;
      width: 68px;
      height: 68px;
      background: linear-gradient(135deg, rgba(61, 155, 63, 0.15), rgba(0, 212, 170, 0.1));
      border: 1px solid rgba(61, 155, 63, 0.25);
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      transition: all var(--transition);
    }

    .sys-card:hover .card-icon-wrap {
      background: linear-gradient(135deg, rgba(61, 155, 63, 0.3), rgba(0, 212, 170, 0.2));
      border-color: rgba(61, 155, 63, 0.5);
      transform: scale(1.1);
      box-shadow: 0 4px 20px rgba(61, 155, 63, 0.3);
    }

    .card-name {
      position: relative;
      z-index: 1;
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text-primary);
      text-align: center;
    }

    .card-tag {
      position: relative;
      z-index: 1;
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--nova-green-light);
      background: rgba(61, 155, 63, 0.12);
      border: 1px solid rgba(61, 155, 63, 0.2);
      border-radius: 20px;
      padding: 0.2rem 0.6rem;
    }

    /* ── Tooltip ── */
    .tooltip-text {
      position: absolute;
      bottom: calc(100% + 12px);
      left: 50%;
      transform: translateX(-50%) scale(0.9);
      background: rgba(13, 17, 23, 0.98);
      border: 1px solid rgba(61, 155, 63, 0.3);
      border-radius: 10px;
      padding: 0.6rem 0.85rem;
      color: var(--text-primary);
      font-size: 0.78rem;
      font-weight: 400;
      line-height: 1.4;
      white-space: normal;
      width: 210px;
      text-align: center;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.2s ease, transform 0.2s ease;
      z-index: 100;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
    }

    .tooltip-text::after {
      content: '';
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(61, 155, 63, 0.3);
    }

    .sys-card:hover .tooltip-text {
      opacity: 1;
      transform: translateX(-50%) scale(1);
    }

    /* ── Footer ── */
    .dashboard-footer {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 1rem;
      color: var(--text-secondary);
      font-size: 0.72rem;
      border-top: 1px solid var(--border);
      opacity: 0.6;
    }

    /* =============================================
       RESPONSIVE
    ============================================= */
    @media (max-width: 600px) {
      .header {
        padding: 0 1rem;
      }

      .header-titles h2 {
        font-size: 0.9rem;
      }

      .user-badge span {
        display: none;
      }

      .btn-logout span {
        display: none;
      }

      .cards-grid {
        gap: 1rem;
      }

      .sys-card {
        width: 155px;
        padding: 1.25rem 0.9rem;
      }

      .card-icon-wrap {
        width: 56px;
        height: 56px;
        font-size: 1.5rem;
      }

      .tooltip-text {
        width: 170px;
        bottom: auto;
        top: calc(100% + 10px);
      }

      .tooltip-text::after {
        top: auto;
        bottom: 100%;
        border-top-color: transparent;
        border-bottom-color: rgba(61, 155, 63, 0.3);
      }
    }
  </style>
</head>

<body>

  <!-- ═══════════════════════════════════════════
       LOGIN PAGE
  ════════════════════════════════════════════ -->
  <div id="login-page">
    <div class="login-container">
      <div class="login-card">

        <!-- Brand -->
        <div class="login-brand">
          <div class="brand-icon">🌐</div>
          <h1>NovaSistemas</h1>
          <p>Portal interno de Novafiber</p>
        </div>

        <!-- Form -->
        <form id="login-form" novalidate>

          <!-- Error message (hidden initially) -->
          <div id="login-error" class="hidden">
            ⚠️ <span id="login-error-msg">Usuario o contraseña incorrectos.</span>
          </div>

          <!-- Username -->
          <div class="form-group">
            <label for="username">Usuario</label>
            <div class="input-wrap">
              <span class="input-icon">👤</span>
              <input type="text" id="username" name="username" placeholder="Ingresa tu usuario" autocomplete="username"
                required />
            </div>
          </div>

          <!-- Password -->
          <div class="form-group">
            <label for="password">Contraseña</label>
            <div class="input-wrap">
              <span class="input-icon">🔒</span>
              <input type="password" id="password" name="password" placeholder="••••••••"
                autocomplete="current-password" required />
            </div>
          </div>

          <button type="submit" class="btn-login" id="btn-login">
            Ingresar →
          </button>
        </form>

        <div class="login-footer">Desarrollado por E.Montenegro & G. Hernández</div>
      </div>
    </div>
  </div>


  <!-- ═══════════════════════════════════════════
       DASHBOARD PAGE
  ════════════════════════════════════════════ -->
  <div id="dashboard-page" class="hidden">

    <!-- Header -->
    <header class="header">
      <div class="header-brand">
        <div class="header-logo">🌐</div>
        <div class="header-titles">
          <h2>NovaSistemas</h2>
          <span>Portal de Novafiber</span>
        </div>
      </div>

      <div class="header-right">
        <div class="user-badge">
          <div class="user-dot"></div>
          <span id="display-user">–</span>
        </div>
        <button class="btn-logout" id="btn-logout" title="Cerrar sesión">
          🚪 <span>Salir</span>
        </button>
      </div>
    </header>

    <!-- Welcome Banner -->
    <div class="welcome-banner">
      <h3>Bienvenido a NovaSistemas</h3>
      <p>Selecciona el sistema al que deseas acceder</p>
    </div>

    <!-- Cards -->
    <section class="cards-section">
      <div class="cards-grid" id="cards-grid">
        <!-- Cards injected by JS -->
      </div>
    </section>

    <!-- Footer -->
    <footer class="dashboard-footer">
      © 2025 Novafiber · NovaSistemas v2.0 · Todos los derechos reservados
    </footer>
  </div>


  <!-- ═══════════════════════════════════════════
       JAVASCRIPT
  ════════════════════════════════════════════ -->
  <script>
    'use strict';

    /* ──────────────────────────────
       USERS & SYSTEMS CONFIGURATION
    ────────────────────────────── */

    /** Credenciales de usuario (simuladas, sin backend) */
    const USERS = {
      user: { password: '1234', role: 'usuario', displayName: 'Usuario General' },
      admin: { password: '1234', role: 'IT', displayName: 'Administrador IT' }
    };

    /** Definición de los sistemas disponibles */
    const SYSTEMS = [
      {
        id: 'nova-activos',
        name: 'NovaActivos',
        icon: '🏢',
        tag: 'Inventario',
        tooltip: 'Sistema para el control de activos por área.',
        url: 'https://script.google.com/a/macros/novafiber.com.gt/s/AKfycbzP_BswcJwhMlPddRsYYb8PBd-XCOGYD2S_WNkWxh_8FKbvlFkYaTchVFGO_3LpH6W_/exec',
        roles: ['usuario', 'IT']
      },
      {
        id: 'nova-cronos',
        name: 'NovaCronos',
        icon: '⏱️',
        tag: 'RRHH',
        tooltip: 'Sistema para la gestión de horas extra sin marcaje.',
        url: 'https://script.google.com/a/macros/novafiber.com.gt/s/AKfycbzuIQiHgSLhtInBJVj0ybYh0gTeQ7C6LgwMlZQTMQnHXoI1Gc4iJ69Zgk9SuYI17OyhNg/exec',
        roles: ['usuario', 'IT']
      },
      {
        id: 'nova-ticket',
        name: 'NovaTicket',
        icon: '🎫',
        tag: 'Soporte IT',
        tooltip: 'Sistema para solicitar apoyo de IT Novafiber.',
        url: 'https://script.google.com/a/macros/novafiber.com.gt/s/AKfycbzdLNgyHefkqUMDbkCmdk74GJ_VInepiBkbJvhLlsHufFuNw-uHHJjXh2WC4gxiM6GujA/exec',
        roles: ['usuario', 'IT']
      },
      {
        id: 'nova-backup',
        name: 'NovaBackup',
        icon: '💾',
        tag: 'Local · IT',
        tooltip: 'Sistema para generar el backup y visualizarlo (funciona de forma local).',
        url: 'http://localhost:3000',
        roles: ['IT']
      },
      {
        id: 'nova-impresoras',
        name: 'NovaImpresoras',
        icon: '🖨️',
        tag: 'Local · IT',
        tooltip: 'Sistema para el control de tóner de impresoras (funciona de forma local).',
        url: 'http://localhost:3000',
        roles: ['IT']
      }
    ];

    /* ──────────────────────────────
       DOM REFERENCES
    ────────────────────────────── */
    const loginPage = document.getElementById('login-page');
    const dashboardPage = document.getElementById('dashboard-page');
    const loginForm = document.getElementById('login-form');
    const usernameInput = document.getElementById('username');
    const passwordInput = document.getElementById('password');
    const loginError = document.getElementById('login-error');
    const loginErrorMsg = document.getElementById('login-error-msg');
    const displayUser = document.getElementById('display-user');
    const cardsGrid = document.getElementById('cards-grid');
    const btnLogout = document.getElementById('btn-logout');

    /* ──────────────────────────────
       SESSION MANAGEMENT
       Usa localStorage para persistir sesión entre recargas
    ────────────────────────────── */
    const SESSION_KEY = 'novafiber_session';

    function saveSession(username, role, displayName) {
      localStorage.setItem(SESSION_KEY, JSON.stringify({ username, role, displayName }));
    }

    function loadSession() {
      try {
        const raw = localStorage.getItem(SESSION_KEY);
        return raw ? JSON.parse(raw) : null;
      } catch {
        return null;
      }
    }

    function clearSession() {
      localStorage.removeItem(SESSION_KEY);
    }

    /* ──────────────────────────────
       SHOW / HIDE PAGES
    ────────────────────────────── */
    function showLogin() {
      dashboardPage.classList.add('hidden');
      loginPage.classList.remove('hidden');
      loginForm.reset();
      loginError.classList.add('hidden');
    }

    function showDashboard(session) {
      loginPage.classList.add('hidden');
      dashboardPage.classList.remove('hidden');

      // Update user badge
      displayUser.textContent = `${session.displayName} · ${session.role}`;

      // Render cards filtered by role
      renderCards(session.role);
    }

    /* ──────────────────────────────
       RENDER SYSTEM CARDS
    ────────────────────────────── */
    function renderCards(role) {
      cardsGrid.innerHTML = '';

      const visible = SYSTEMS.filter(sys => sys.roles.includes(role));

      visible.forEach(sys => {
        const card = document.createElement('a');
        card.href = sys.url;
        card.target = '_blank';
        card.rel = 'noopener noreferrer';
        card.className = 'sys-card';
        card.id = sys.id;
        card.setAttribute('aria-label', `${sys.name}: ${sys.tooltip}`);

        card.innerHTML = `
          <div class="card-icon-wrap">${sys.icon}</div>
          <div class="card-name">${sys.name}</div>
          <div class="card-tag">${sys.tag}</div>
          <div class="tooltip-text">${sys.tooltip}</div>
        `;

        cardsGrid.appendChild(card);
      });
    }

    /* ──────────────────────────────
       LOGIN LOGIC
    ────────────────────────────── */
    function showError(msg) {
      loginErrorMsg.textContent = msg;
      loginError.classList.remove('hidden');
      // Re-trigger shake animation
      loginError.style.animation = 'none';
      loginError.offsetHeight; // reflow
      loginError.style.animation = '';
    }

    loginForm.addEventListener('submit', function (e) {
      e.preventDefault();

      const username = usernameInput.value.trim().toLowerCase();
      const password = passwordInput.value;

      // Basic empty check
      if (!username || !password) {
        showError('Por favor completa todos los campos.');
        return;
      }

      const userRecord = USERS[username];

      if (!userRecord || userRecord.password !== password) {
        showError('Usuario o contraseña incorrectos. Intenta de nuevo.');
        passwordInput.value = '';
        passwordInput.focus();
        return;
      }

      // Credentials OK → save session and go to dashboard
      const session = {
        username: username,
        role: userRecord.role,
        displayName: userRecord.displayName
      };

      saveSession(session.username, session.role, session.displayName);
      showDashboard(session);
    });

    /* ──────────────────────────────
       LOGOUT
    ────────────────────────────── */
    btnLogout.addEventListener('click', function () {
      clearSession();
      showLogin();
    });

    /* ──────────────────────────────
       INIT: Check for existing session
    ────────────────────────────── */
    (function init() {
      const session = loadSession();
      if (session) {
        showDashboard(session);
      } else {
        showLogin();
      }
    })();
  </script>

</body>

